ErrorDocument 404 /404.php
<IfModule mod_rewrite.c>

RewriteEngine On
RewriteCond %{REQUEST_URI} !-f
RewriteCond %{REQUEST_URI} !.(css|gif|ico|jpg|js|png|swf|txt|php|pdf|csv|bmp|zip|xls|xlsx|doc|docx)$
RewriteCond %{REQUEST_URI} !-d
RewriteRule ^(.*)$ index.php?view=$1 [QSA,L]

</IfModule>

<Files ~ "\.(env|json|config.js|md|xml|gitignore|gitattributes|lock|editorconfig|yml|styleci.yml)$">
     Order allow,deny
     Deny from all
 </Files>
 Options -Indexes
 <Files ~ "(artisan|package.json|webpack.mix.js)$">
     Order allow,deny
     Deny from all
 </Files>